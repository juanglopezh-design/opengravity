  "auth": {
    "providers": {
      "anonymous": false,
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "ContentFlow AI",
        "supportEmail": "juanglopezh@gmail.com"
      }
    }
  },
  "hosting": {
    "source": ".",
