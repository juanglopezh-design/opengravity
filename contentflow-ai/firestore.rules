rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Allow users to create their own doc upon signup, ensuring they default to 'free' plan
      allow create: if request.auth != null && request.auth.uid == userId 
                    && request.resource.data.plan == 'free'
                    && request.resource.data.generationsUsed == 0;
      // Disallow user from updating their own document to prevent tampering with plan/credits
      allow update: if false;
      allow delete: if false;

      match /history/{historyId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // History is written by the server API, so client writes are disabled
        allow write: if false;
      }
    }
  }
}
